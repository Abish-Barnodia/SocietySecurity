# Application
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_SECRET=your_super_secret_key_min_32_chars_override_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_override_me_please
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (Push Notifications, Auth, etc.)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email@appspot.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Twilio (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP Email
SMTP_USER=
SMTP_PASS=

# WhatsApp API
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Miscellaneous
QR_HMAC_SECRET=your_qr_signing_secret_override_me_please
OTP_EXPIRY_MINUTES=10
EMERGENCY_SMS_NUMBER=

# Clients URIs
CLIENT_RESIDENT_APP_URL=http://localhost:3000
CLIENT_GUARD_APP_URL=http://localhost:3001
CLIENT_MANAGER_URL=http://localhost:3002
