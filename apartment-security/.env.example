# Application
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
REDIS_URL=redis://localhost:6379

# JWT Secrets — REQUIRED. Generate strong values with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_STRONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (Push Notifications, Auth, etc.)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email@appspot.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Twilio (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SMTP Email
SMTP_USER=
SMTP_PASS=

# WhatsApp API
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# QR signing secret — REQUIRED. Same generation as JWT secrets above.
QR_HMAC_SECRET=REPLACE_WITH_A_STRONG_RANDOM_QR_SECRET_MIN_32_CHARS
OTP_EXPIRY_MINUTES=10
EMERGENCY_SMS_NUMBER=

# Clients URIs
CLIENT_RESIDENT_APP_URL=http://localhost:3000
CLIENT_GUARD_APP_URL=http://localhost:3001
CLIENT_MANAGER_URL=http://localhost:3002
